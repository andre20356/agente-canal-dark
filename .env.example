# Obrigatório — Google AI Studio (gratuito): studio.google.com → Get API Key
GEMINI_API_KEY=

# YouTube OAuth2 — console.cloud.google.com → Credenciais → OAuth 2.0 (Aplicativo Desktop)
# Após obter client_id e client_secret, rode: node scripts/autenticar_youtube.js
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=   # preenchido automaticamente pelo script de autenticação

# Canal de teste (opcional) — pra testar o Canal de Cortes sem publicar no
# canal principal. Client ID/Secret podem ficar vazios (usa os de cima, mesmo
# app OAuth) — só rode: node scripts/autenticar_youtube.js --teste
# Alterna qual canal recebe upload via toggle no painel ou YOUTUBE_MODO=teste/real.
YOUTUBE_MODO=real
YOUTUBE_TEST_CLIENT_ID=
YOUTUBE_TEST_CLIENT_SECRET=
YOUTUBE_TEST_REFRESH_TOKEN=

# TikTok Content Posting API (opcional) — developers.tiktok.com → seu app → Login Kit
# Requer redirect URI cadastrado: http://localhost:4006/oauth2callback
# Após obter client_key e client_secret, rode: node scripts/autenticar_tiktok.js
# IMPORTANTE: enquanto o app não passar pela auditoria do TikTok, todo vídeo
# publicado sai como privado (SELF_ONLY), forçado pelo lado do TikTok.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=       # preenchido automaticamente
TIKTOK_REFRESH_TOKEN=      # preenchido automaticamente
TIKTOK_TOKEN_EXPIRES_AT=   # preenchido automaticamente
TIKTOK_OPEN_ID=            # preenchido automaticamente
TIKTOK_PRIVACY_LEVEL=SELF_ONLY   # PUBLIC_TO_EVERYONE só funciona depois da auditoria do app
TIKTOK_AUDITADO=false      # mude pra true manualmente quando o app passar na auditoria
PUBLICAR_TIKTOK=false      # liga/desliga publicação automática no TikTok (também via painel)

# Narração é 100% Edge TTS (gratuito, sem chave) — ElevenLabs removido em 2026-07-03

# Opcional — gera thumbnail automaticamente
OPENAI_API_KEY=
